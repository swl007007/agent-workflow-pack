{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-workflow.provider-release-receipt",
  "x-schema-version": 1,
  "x-definition-owner": "task-2",
  "x-implementation-owner": "task-2",
  "x-digest-domains": ["agent-workflow.provider-release-receipt.v1"],
  "type": "object", "additionalProperties": false,
  "required": ["schema_id", "schema_version", "workspace_instance_id", "provider_plan_digest", "prospective_transaction_id", "attempt_id", "release_token_digest", "broker_liveness_identity", "released_at"],
  "properties": {
    "schema_id": {"const": "agent-workflow.provider-release-receipt"},
    "schema_version": {"const": 1},
    "workspace_instance_id": {"$ref": "#/definitions/uuid"},
    "provider_plan_digest": {"$ref": "#/definitions/sha256"},
    "prospective_transaction_id": {"$ref": "#/definitions/uuid"},
    "attempt_id": {"$ref": "#/definitions/uuid"},
    "release_token_digest": {"$ref": "#/definitions/sha256"},
    "broker_liveness_identity": {"type": "string", "minLength": 1},
    "released_at": {"type": "string", "minLength": 1}
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uuid": {"type": "string", "pattern": "^[0-9a-f-]{36}$"}
  }
}
