{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-workflow.archive-policy",
  "x-schema-version": 1,
  "x-definition-owner": "task-2",
  "x-implementation-owner": "task-2",
  "x-digest-domains": [],
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "allowed_formats", "max_members", "max_file_bytes", "max_expanded_bytes", "max_depth", "max_compression_ratio", "allow_executable"],
  "properties": {
    "schema_id": {"const": "agent-workflow.archive-policy"},
    "schema_version": {"const": 1},
    "allowed_formats": {"type": "array", "minItems": 1, "items": {"enum": ["tar", "zip"]}},
    "max_members": {"type": "integer", "minimum": 1},
    "max_file_bytes": {"type": "integer", "minimum": 1},
    "max_expanded_bytes": {"type": "integer", "minimum": 1},
    "max_depth": {"type": "integer", "minimum": 1},
    "max_compression_ratio": {"type": "integer", "minimum": 1},
    "allow_executable": {"type": "boolean"}
  }
}
