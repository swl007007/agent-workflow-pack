{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow.workflow-lock",
  "x-schema-version": 1,
  "x-definition-owner": "task-1",
  "x-implementation-owner": "task-1",
  "x-digest-domains": ["agent-workflow.workflow-lock.v1"],
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "components"],
  "properties": {
    "schema_id": {"const": "agent-workflow.workflow-lock"},
    "schema_version": {"const": 1},
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "version",
          "source_sha256",
          "content_digest",
          "provider_id",
          "acquisition_id"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9._-]*$"},
          "version": {"type": "string", "minLength": 1},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "content_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "provider_id": {"type": "string", "minLength": 1},
          "acquisition_id": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
