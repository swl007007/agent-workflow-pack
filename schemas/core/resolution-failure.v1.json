{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow.resolution-failure",
  "x-schema-version": 1,
  "x-definition-owner": "task-1",
  "x-implementation-owner": "task-1",
  "x-digest-domains": [],
  "title": "Agent Workflow Pack structured Core failure",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "code",
    "exit_code",
    "message",
    "path",
    "details"
  ],
  "properties": {
    "schema_id": {"const": "agent-workflow.resolution-failure"},
    "schema_version": {"const": 1},
    "code": {"type": "string", "pattern": "^AWP_[A-Z0-9_]+$"},
    "exit_code": {"enum": [2, 20, 21, 22, 23, 30, 31, 40, 70]},
    "message": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "details": {"type": "object"}
  }
}
