{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-workflow.runtime-surface-registry",
  "x-schema-version": 1,
  "x-definition-owner": "task-1",
  "x-implementation-owner": "task-1",
  "x-digest-domains": ["agent-workflow.surface-registry.v1", "agent-workflow.runtime-surface.v1"],
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "surfaces"],
  "properties": {
    "schema_id": {"const": "agent-workflow.runtime-surface-registry"},
    "schema_version": {"const": 1},
    "surfaces": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "surface_kind",
          "descriptor_version",
          "digest_recipe_id",
          "owned_unit_ids",
          "references",
          "contract_change_class"
        ],
        "properties": {
          "surface_id": {"type": "string", "minLength": 1},
          "surface_kind": {"type": "string", "minLength": 1},
          "descriptor_version": {"const": 1},
          "digest_recipe_id": {"const": "surface-content-v1"},
          "owned_unit_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "references": {"type": "array", "items": {"type": "string"}},
          "contract_change_class": {"const": "runtime-visible"}
        }
      }
    }
  }
}
