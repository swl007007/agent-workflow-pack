{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow.schema-catalog",
  "x-schema-version": 1,
  "x-definition-owner": "task-1",
  "x-implementation-owner": "task-1",
  "x-digest-domains": [],
  "title": "Agent Workflow Pack schema catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "schemas"],
  "properties": {
    "schema_id": {"const": "agent-workflow.schema-catalog"},
    "schema_version": {"const": 1},
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_id",
          "supported_versions",
          "definition_owner",
          "implementation_owner",
          "digest_domains"
        ],
        "properties": {
          "schema_id": {"type": "string", "pattern": "^agent-workflow\\.[a-z0-9-]+$"},
          "supported_versions": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "integer", "minimum": 1}
          },
          "definition_owner": {"type": "string", "pattern": "^task-[1-6]$"},
          "implementation_owner": {"type": "string", "pattern": "^task-[1-6]$"},
          "digest_domains": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[ -~]+\\.v[1-9][0-9]*$"}
          }
        }
      }
    }
  }
}
