{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-workflow.trellis-task-layout",
  "x-schema-version": 1,
  "x-definition-owner": "task-1",
  "x-implementation-owner": "task-1",
  "x-digest-domains": [],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "adapter_id",
    "adapter_version",
    "runtime_namespace",
    "active_root",
    "archive_root",
    "task_discovery",
    "metadata_contracts",
    "task_transaction_discovery"
  ],
  "properties": {
    "schema_id": {"const": "agent-workflow.trellis-task-layout"},
    "schema_version": {"const": 1},
    "adapter_id": {"$ref": "#/definitions/stableToken"},
    "adapter_version": {"type": "string", "minLength": 1},
    "runtime_namespace": {"type": "string", "minLength": 1},
    "active_root": {"type": "string", "minLength": 1},
    "archive_root": {"type": "string", "minLength": 1},
    "task_discovery": {"$ref": "#/definitions/taskDiscovery"},
    "metadata_contracts": {
      "type": "array",
      "items": {
        "oneOf": [
          {"$ref": "#/definitions/exactMetadata"},
          {"$ref": "#/definitions/boundedMetadata"}
        ]
      }
    },
    "task_transaction_discovery": {"$ref": "#/definitions/taskTransactionDiscovery"}
  },
  "definitions": {
    "stableToken": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
    "positiveVersions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "integer", "minimum": 1}
    },
    "jsonPointers": {
      "type": "array",
      "items": {"type": "string", "pattern": "^/"}
    },
    "taskDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hierarchy",
        "segment_grammar_id",
        "integration_relative_path",
        "integration_schema_id",
        "integration_schema_versions",
        "unknown_root_entry_policy",
        "allowed_non_task_entries",
        "max_scan_depth",
        "max_tasks",
        "max_root_entries",
        "max_integration_bytes"
      ],
      "properties": {
        "hierarchy": {"const": "one-segment"},
        "segment_grammar_id": {"const": "safe-nfc-segment-v1"},
        "integration_relative_path": {"type": "string", "minLength": 1},
        "integration_schema_id": {"$ref": "#/definitions/stableToken"},
        "integration_schema_versions": {"$ref": "#/definitions/positiveVersions"},
        "unknown_root_entry_policy": {"const": "block"},
        "allowed_non_task_entries": {"type": "array", "items": {"type": "string"}},
        "max_scan_depth": {"const": 1},
        "max_tasks": {"type": "integer", "minimum": 1},
        "max_root_entries": {"type": "integer", "minimum": 1},
        "max_integration_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "metadataCommon": {
      "type": "object",
      "properties": {
        "kind": {"enum": ["exact", "bounded"]},
        "contract_id": {"$ref": "#/definitions/stableToken"},
        "schema_id": {"$ref": "#/definitions/stableToken"},
        "schema_versions": {"$ref": "#/definitions/positiveVersions"},
        "parser_id": {"$ref": "#/definitions/stableToken"},
        "parser_version": {"type": "integer", "minimum": 1},
        "classifier_id": {"$ref": "#/definitions/stableToken"},
        "classifier_version": {"type": "integer", "minimum": 1},
        "semantic_role": {"$ref": "#/definitions/stableToken"},
        "task_ref_fields": {"$ref": "#/definitions/jsonPointers"},
        "max_bytes": {"type": "integer", "minimum": 1},
        "absence_is_empty": {"type": "boolean"},
        "canonical_empty_state_id": {"$ref": "#/definitions/stableToken"}
      }
    },
    "exactMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "contract_id",
        "path",
        "schema_id",
        "schema_versions",
        "parser_id",
        "parser_version",
        "classifier_id",
        "classifier_version",
        "semantic_role",
        "task_ref_fields",
        "max_bytes",
        "absence_is_empty",
        "canonical_empty_state_id"
      ],
      "properties": {
        "kind": {"const": "exact"},
        "contract_id": {"$ref": "#/definitions/stableToken"},
        "path": {"type": "string", "minLength": 1},
        "schema_id": {"$ref": "#/definitions/stableToken"},
        "schema_versions": {"$ref": "#/definitions/positiveVersions"},
        "parser_id": {"$ref": "#/definitions/stableToken"},
        "parser_version": {"type": "integer", "minimum": 1},
        "classifier_id": {"$ref": "#/definitions/stableToken"},
        "classifier_version": {"type": "integer", "minimum": 1},
        "semantic_role": {"$ref": "#/definitions/stableToken"},
        "task_ref_fields": {"$ref": "#/definitions/jsonPointers"},
        "max_bytes": {"type": "integer", "minimum": 1},
        "absence_is_empty": {"type": "boolean"},
        "canonical_empty_state_id": {"$ref": "#/definitions/stableToken"}
      }
    },
    "boundedMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "contract_id",
        "root",
        "segment_grammar_id",
        "max_depth",
        "max_matches",
        "schema_id",
        "schema_versions",
        "parser_id",
        "parser_version",
        "classifier_id",
        "classifier_version",
        "semantic_role",
        "task_ref_fields",
        "max_bytes",
        "absence_is_empty",
        "canonical_empty_state_id"
      ],
      "properties": {
        "kind": {"const": "bounded"},
        "contract_id": {"$ref": "#/definitions/stableToken"},
        "root": {"type": "string", "minLength": 1},
        "segment_grammar_id": {"enum": ["safe-nfc-segment-v1", "uuid-json-v1"]},
        "max_depth": {"const": 1},
        "max_matches": {"type": "integer", "minimum": 1},
        "schema_id": {"$ref": "#/definitions/stableToken"},
        "schema_versions": {"$ref": "#/definitions/positiveVersions"},
        "parser_id": {"$ref": "#/definitions/stableToken"},
        "parser_version": {"type": "integer", "minimum": 1},
        "classifier_id": {"$ref": "#/definitions/stableToken"},
        "classifier_version": {"type": "integer", "minimum": 1},
        "semantic_role": {"$ref": "#/definitions/stableToken"},
        "task_ref_fields": {"$ref": "#/definitions/jsonPointers"},
        "max_bytes": {"type": "integer", "minimum": 1},
        "absence_is_empty": {"type": "boolean"},
        "canonical_empty_state_id": {"$ref": "#/definitions/stableToken"}
      }
    },
    "taskTransactionDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "filename_grammar_id",
        "schema_id",
        "schema_versions",
        "phase_classifier_id",
        "phase_classifier_version",
        "task_id_field",
        "task_ref_fields",
        "terminal_phases",
        "max_journals",
        "max_journal_bytes"
      ],
      "properties": {
        "root": {"const": ".agent-workflow/task-transactions"},
        "filename_grammar_id": {"const": "uuid-json-v1"},
        "schema_id": {"$ref": "#/definitions/stableToken"},
        "schema_versions": {"$ref": "#/definitions/positiveVersions"},
        "phase_classifier_id": {"$ref": "#/definitions/stableToken"},
        "phase_classifier_version": {"type": "integer", "minimum": 1},
        "task_id_field": {"const": "/task_id"},
        "task_ref_fields": {"$ref": "#/definitions/jsonPointers"},
        "terminal_phases": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "max_journals": {"type": "integer", "minimum": 1},
        "max_journal_bytes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
