{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-workflow.release-trust-policy",
  "x-schema-version": 1,
  "x-definition-owner": "task-6",
  "x-implementation-owner": "task-6",
  "x-digest-domains": ["agent-workflow.release-trust-policy.v1"],
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "policy_id", "host", "owner", "repository", "tag_template", "manifest_asset_name", "api_base_url", "allowed_redirect_hosts", "immutable_release_required", "policy_digest"],
  "properties": {
    "schema_id": {"const": "agent-workflow.release-trust-policy"},
    "schema_version": {"const": 1},
    "policy_id": {"const": "github-immutable-release-v1"},
    "host": {"const": "github.com"},
    "owner": {"type": "string", "minLength": 1},
    "repository": {"type": "string", "minLength": 1},
    "tag_template": {"const": "v{version}"},
    "manifest_asset_name": {"const": "release-manifest.json"},
    "api_base_url": {"const": "https://api.github.com"},
    "allowed_redirect_hosts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "immutable_release_required": {"const": true},
    "policy_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
