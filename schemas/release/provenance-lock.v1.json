{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-workflow.provenance-lock",
  "x-schema-version": 1,
  "x-definition-owner": "task-6",
  "x-implementation-owner": "task-6",
  "x-digest-domains": ["agent-workflow.provenance-lock.v1", "agent-workflow.projected-unit-provenance.v1"],
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "components", "projected_units", "provider_records", "provenance_lock_digest"],
  "properties": {
    "schema_id": {"const": "agent-workflow.provenance-lock"},
    "schema_version": {"const": 1},
    "components": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "kind", "name", "version", "source", "license_expression", "license_file", "install", "modification_notice", "files"],
        "properties": {
          "component_id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["first-party", "vendored-runtime"]},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "source": {"type": "object"},
          "license_expression": {"type": "string", "minLength": 1},
          "license_file": {"type": ["object", "null"]},
          "install": {"type": "object"},
          "modification_notice": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "sha256"],
            "properties": {
              "text": {"type": "string"},
              "sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"const": "canonical-null"}]}
            }
          },
          "files": {"type": "array"}
        }
      }
    },
    "projected_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_id", "platform_adapter", "definition_path", "definition_digest", "source_component_id", "license_expression"],
        "properties": {
          "unit_id": {"type": "string", "minLength": 1},
          "platform_adapter": {"type": "string", "minLength": 1},
          "definition_path": {"type": "string", "minLength": 1},
          "definition_digest": {"$ref": "#/$defs/sha256"},
          "source_component_id": {"const": "first-party:agent-workflow-pack"},
          "license_expression": {"const": "Apache-2.0"}
        }
      }
    },
    "provider_records": {"type": "array"},
    "provenance_lock_digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
